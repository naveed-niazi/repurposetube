# Supabase — from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SITE_URL=http://localhost:3003
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Auth provider setup
# - In Supabase Auth URL settings, add:
#   Site URL: http://localhost:3003
#   Redirect URLs:
#   - http://localhost:3003/auth/callback
#   - https://your-production-domain.com/auth/callback
# - Enable Google provider and configure client credentials in Supabase dashboard.

# AI provider routing (openai | anthropic | gemini)
AI_PROVIDER=openai

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
AI_MODEL_OPENAI=gpt-4o-mini

# Anthropic (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL_ANTHROPIC=claude-3-5-sonnet-latest

# Gemini (required if AI_PROVIDER=gemini)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
AI_MODEL_GEMINI=gemini-2.0-flash

# Supabase Postgres — from your Supabase project dashboard → Settings → Database
SUPABASE_POSTGRES_URL=postgres://...
SUPABASE_POSTGRES_URL_NON_POOLING=postgres://...
SUPABASE_POSTGRES_PRISMA_URL=postgres://...?pgbouncer=true
SUPABASE_POSTGRES_HOST=your-db-host.supabase.co
SUPABASE_POSTGRES_DATABASE=postgres
SUPABASE_POSTGRES_USER=postgres
SUPABASE_POSTGRES_PASSWORD=your-db-password

# Before deploying, run this SQL in Supabase dashboard → SQL Editor:
#
# create table if not exists waitlist (
#   id         bigserial primary key,
#   email      text not null unique,
#   name       text,
#   role       text,
#   created_at timestamptz not null default now()
# );
