# Supabase — from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Supabase Postgres — from your Supabase project dashboard → Settings → Database
SUPABASE_POSTGRES_URL=postgres://...
SUPABASE_POSTGRES_URL_NON_POOLING=postgres://...
SUPABASE_POSTGRES_PRISMA_URL=postgres://...?pgbouncer=true
SUPABASE_POSTGRES_HOST=your-db-host.supabase.co
SUPABASE_POSTGRES_DATABASE=postgres
SUPABASE_POSTGRES_USER=postgres
SUPABASE_POSTGRES_PASSWORD=your-db-password

# Before deploying, run this SQL in Supabase dashboard → SQL Editor:
#
# create table if not exists waitlist (
#   id         bigserial primary key,
#   email      text not null unique,
#   name       text,
#   role       text,
#   created_at timestamptz not null default now()
# );
