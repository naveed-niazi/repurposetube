generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Waitlist {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      String?
  createdAt DateTime @default(now())

  @@map("waitlist")
}
